{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/studyreadbook4ever/cinuxx-myskill/main/skills/ciduxx/schemas/exhibit-v1.schema.json",
  "title": "Ciduxx Semantic Change Exhibit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "document",
    "turns"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "kind": {
      "const": "ciduxx.semantic-change-exhibit"
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "created_at",
        "updated_at",
        "revision",
        "skin"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^doc-[0-9a-f]{12}$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "revision": {
          "type": "integer",
          "minimum": 0
        },
        "skin": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100,
              "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
            }
          }
        }
      }
    },
    "turns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/turn"
      }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client",
        "display_name"
      ],
      "properties": {
        "client": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,63}$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        }
      }
    },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sequence",
        "text",
        "recorded_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^chg-[0-9a-f]{12}$"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "text": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100000
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sequence",
        "status",
        "requested_at",
        "answered_at",
        "request",
        "agent",
        "idempotency_key",
        "changes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^turn-[0-9a-f]{12}$"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "enum": [
            "pending",
            "answered",
            "partial"
          ]
        },
        "requested_at": {
          "type": "string",
          "format": "date-time"
        },
        "answered_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "request": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "text",
            "redacted"
          ],
          "properties": {
            "text": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100000
            },
            "redacted": {
              "type": "boolean"
            }
          }
        },
        "agent": {
          "$ref": "#/$defs/agent"
        },
        "idempotency_key": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 300
        },
        "changes": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/change"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "pending"
              }
            }
          },
          "then": {
            "properties": {
              "answered_at": {
                "type": "null"
              },
              "changes": {
                "maxItems": 0
              }
            }
          },
          "else": {
            "properties": {
              "answered_at": {
                "type": "string",
                "format": "date-time"
              },
              "changes": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  }
}
